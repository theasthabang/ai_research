      {
        "page_title": "Deadlock Problem",
        "center_topic": "Resource Allocation",
        "branches": [
          {
            "name": "Deadlock Definition",
            "color": "#96CEB4",
            "sub_branches": [
              {
                "name": "Process Waiting",
                "points": [
                  "Process requests a resource",
                  "Resource is busy or not available"
                ]
              },
              {
                "name": "Circular Wait",
                "points": [
                  "Two or more processes waiting on resources",
                  "Resources are busy or not available"
                ]
              }
            ]
          },
          {
            "name": "Solution",
            "color": "#FFEAA7",
            "sub_branches": [
              {
                "name": "Semaphore Solution",
                "points": [
                  "Each fork is a binary semaphore",
                  "Ph. calls wait() operation to acquire a fork"
                ]
              },
              {
                "name": "Enhancement Rules",
                "points": [
                  "Allow at most 4 ph. to be sitting simultaneously",
                  "Odd-even rule"
                ]
              }
            ]
          },
          {
            "name": "Deadlock Avoidance",
            "color": "#DDA0DD",
            "sub_branches": [
              {
                "name": "Safe State",
                "points": [
                  "A state is safe if the system can allocate resources",
                  "Avoid Deadlock"
                ]
              },
              {
                "name": "Resource Allocation",
                "points": [
                  "Schedule process and its resources allocation",
                  "Avoid Deadlock"
                ]
              }
            ]
          }
        ],
        "key_facts": [
          "Deadlock occurs when two or more processes are waiting on resources",
          "Deadlock avoidance is achieved by scheduling process and its resources allocation"
        ],
        "exam_corner": [
          "Understand the concept of Deadlock",
          "Know the solution to Deadlock problem"
        ]
      },
      {
