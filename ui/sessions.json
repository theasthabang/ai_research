            "name": "Critical Section",
            "color": "#FF6B6B",
            "sub_branches": [
              {
                "name": "Definition",
                "points": [
                  "Segment of code accessing shared resources",
                  "Processes/threads execute concurrently"
                ]
              },
              {
                "name": "Issues",
                "points": [
                  "Race Condition",
                  "Thread scheduling issue"
                ]
              }
            ]
          },
          {
            "name": "Solution",
            "color": "#4ECDC4",
            "sub_branches": [
              {
                "name": "Atomic Operations",
                "points": [
                  "Make Critical code section atomic",
                  "Executed in one CPU cycle"
                ]
              },
              {
                "name": "Mutual Exclusion",
                "points": [
                  "Using locks",
                  "Semaphores"
                ]
              }
            ]
          },
