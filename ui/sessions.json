              },
              {
                "name": "Locking Resources",
                "points": [
                  "Locking resources in a specific order",
                  "Avoid Deadlock"
                ]
              }
            ]
          },
          {
            "name": "Deadlock Detection",
            "color": "#6BCB77",
            "sub_branches": [
              {
                "name": "Detecting Deadlock",
                "points": [
                  "Detecting Deadlock using resource allocation graph",
                  "Avoiding Deadlock"
                ]
              },
              {
                "name": "Recovering from Deadlock",
                "points": [
                  "Recovering from Deadlock by aborting one process",
                  "Avoiding Deadlock"
                ]
              }
            ]
          },
          {
            "name": "Deadlock Recovery",
            "color": "#FF6B6B",
            "sub_branches": [
              {
                "name": "Abort One Process",
