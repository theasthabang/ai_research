            "name": "Locks",
            "color": "#45B7D1",
            "sub_branches": [
              {
                "name": "Advantages",
                "points": [
                  "Implement mutual exclusion",
                  "Avoid race condition"
                ]
              },
              {
                "name": "Disadvantages",
                "points": [
                  "Contention",
                  "Deadlocks",
                  "Debugging",
                  "Starvation"
                ]
              }
            ]
          }
        ],
        "key_facts": [
          "Process synchronization techniques maintain consistency",
          "Critical Section is a segment of code accessing shared resources"
