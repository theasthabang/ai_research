                ]
              }
            ]
          },
          {
            "name": "Optimal Page Replacement",
            "color": "#45B7D1",
            "sub_branches": [
              {
                "name": "How it Works",
                "points": [
                  "Find if a page that is not in memory",
                  "Replace the page that will not be used"
                ]
              },
              {
                "name": "Advantages",
                "points": [
                  "Reduces page faults",
                  "Good performance"
                ]
              }
            ]
          },
          {
            "name": "Page Fault Handling",
            "color": "#4ECDC4",
            "sub_branches": [
              {
                "name": "What is Page Fault",
                "points": [
                  "Occurs when a page is not in memory",
                  "OS must bring the page from swap-space"
                ]
              },
              {
                "name": "Page Replacement",
                "points": [
